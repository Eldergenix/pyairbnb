{
  "name": "@eldergenix/pyairbnb-mcp",
  "version": "3.2.0",
  "private": true,
  "type": "module",
  "description": "Low-latency Airbnb search MCP server for OpenAI and Anthropic agents",
  "scripts": {
    "dev": "wrangler dev --port 8788",
    "deploy": "wrangler deploy --minify",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:mcp": "node scripts/verify-mcp.mjs",
    "check": "npm run typecheck && npm test && wrangler deploy --dry-run --outdir /tmp/pyairbnb-worker-build",
    "cf:types": "wrangler types worker-configuration.d.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "1.7.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "agents": "0.17.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@openuidev/react-lang": "^0.2.8",
    "@types/node": "26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  },
  "engines": {
    "node": ">=20"
  }
}
